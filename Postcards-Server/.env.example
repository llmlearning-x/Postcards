# 数据库 — 阿里云 RDS
DB_HOST=rm-bp12t8q5bo58ct10d4o.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_NAME=postcards
DB_USER=postcards_app
DB_PASS=

# JWT 密钥（部署时替换为随机字符串）
