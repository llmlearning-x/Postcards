# 数据库 — 阿里云 RDS
DB_HOST=your-rds-host.mysql.rds.aliyuncs.com
DB_PORT=3306
DB_NAME=postcards
DB_USER=postcards_app
DB_PASS=

# JWT 密钥（部署时替换为随机字符串）
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_REFRESH_SECRET=change-this-to-another-random-64-char-string

# 服务配置
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# 图片存储目录（绝对路径）
UPLOAD_DIR=/data/postcards/uploads
# 图片访问域名/IP（拼接到 URL 里）
UPLOAD_BASE_URL=http://115.175.15.145/uploads

# CORS 允许的来源（生产环境设置为前端域名，如 https://your-app.com）
CORS_ORIGIN=http://localhost:3000

# 图片限制
MAX_FILE_SIZE_MB=10
